library(tidyverse)
voitures = tibble(mtcars) # Le format de données préféré du tidyverse
# Le pipe il est dans magrittr
64 %>% log(2) %>% exp()
voitures %>% names() # Avoir les noms de colonnes
voitures$mpg # Méthodes sans tibble
# Méthodes avec tibble :
voitures %>% select(mpg, cyl) %>% summarise(mpg_moyenne = mean(mpg),
cyl_moyenne = mean(cyl),
mpg_sd = sd(mpg),
cyl_sd = sd(cyl)
) %>% round(2) -> statdes
library(kableExtra)
pivot_longer(statdes,
cols = everything(),
names_to = c("variable", ".value"),
names_sep = "_"
) %>% kable(
caption = "Statistiques descriptives des véhicules",
col.names = c("Variable", "Moyenne", "Écart-type (SD)"),
align = "lrr", # Gauche pour le texte, Droite pour les chiffres
digits = 2     # Arrondi à 2 décimales
) %>%
kable_styling(
bootstrap_options = c("striped", "hover", "condensed"),
full_width = FALSE,
position = "left"
) %>%
column_spec(1, bold = TRUE, color = "white", background = "tomato") # Met en valeur les noms de variables
stargazer(statdes)
stargazer(statdes, type = "html")
stargazer(statdes, type = "text")
stargazer(voitures, type = "text")
stargazer(voitures)
stargazer(voitures, type = "text", out = "models.htm" )
stargazer(model, type = "text")
model = lm(mpg ~ hp, data = voitures)
stargazer(model, type = "text")
model = voitures %>% lm(mpg ~ hp)
plot(model)
stargazer(model, type = "text")
voitures %>% ggplot(aes(hp, mpg))
voitures %>% ggplot(aes(hp, mpg)) %>% geom_point()
voitures %>% ggplot(aes(hp, mpg)) + geom_point()
voitures %>% ggplot(aes(hp, mpg)) + geom_point() + theme_minimal()
