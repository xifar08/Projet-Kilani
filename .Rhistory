# 2. Logique serveur
server <- function(input, output, session) {
# Création du titre dynamique avec les bons délimiteurs MathJax
output$titre_dynamique <- renderUI({
withMathJax(HTML(paste0(
"Exploration de la loi \\( \\Gamma(\\alpha = ", input$alpha, ", \\lambda = ", input$lambda, ") \\)"
)))
})
output$graphique_gamma <- renderPlot({
par(bg = "#f8f9fa", mar = c(5, 5, 4, 2) + 0.1) # Marge supérieure agrandie pour le titre
# Préparation du graphique vide
plot(0, 0, type = "n", xlim = c(0, 10),
ylim = c(0, max(dgamma(seq(0.1, 10, length.out = 100), input$alpha, input$lambda))),
xlab = "Valeurs de x", ylab = "Densité f(x)", cex.lab = 1.2, cex.axis = 1.1,
# bquote() permet d'interpréter dynamiquement les variables en langage mathématique R
main = bquote("Densité pour" ~ alpha == .(input$alpha) ~ "et" ~ lambda == .(input$lambda))
)
# Ajout de la grille
grid(col = "white", lty = "solid", lwd = 1.5)
# Tracé de la courbe
curve(
dgamma(x, shape = input$alpha, rate = input$lambda),
from = 0.01,
to = 10,
col = "#e74c3c",
lwd = 3,
add = TRUE
)
})
}
# 3. Lancement de l'application
#shinyApp(ui, server)
#| echo: false
library(shiny)
library(bslib)
# 1. Interface utilisateur (UI)
ui <- page_sidebar(
theme = bs_theme(version = 5, bootswatch = "flatly"),
withMathJax(),
sidebar = sidebar(
title = "Paramètres de la loi",
sliderInput("alpha", "$\\alpha$ (Forme) :", min = 0, max = 10, value = 1, step = 0.1),
sliderInput("lambda", "$\\lambda$ (Taux) :", min = 0, max = 10, value = 3, step = 0.1)
),
card(
# L'en-tête est maintenant dynamique (défini dans le serveur)
card_header(uiOutput("titre_dynamique")),
card_body(
p("La fonction de densité est donnée par : $$f(x) = \\frac{\\lambda^\\alpha}{\\Gamma(\\alpha)} x^{\\alpha-1} e^{-\\lambda x}$$"),
plotOutput("graphique_gamma")
)
)
)
# 2. Logique serveur
server <- function(input, output, session) {
# Création du titre dynamique avec les bons délimiteurs MathJax
output$titre_dynamique <- renderUI({
withMathJax(HTML(paste0(
"Exploration de la loi \\( \\Gamma(\\alpha = ", input$alpha, ", \\lambda = ", input$lambda, ") \\)"
)))
})
output$graphique_gamma <- renderPlot({
par(bg = "#f8f9fa", mar = c(5, 5, 4, 2) + 0.1) # Marge supérieure agrandie pour le titre
# Préparation du graphique vide
plot(0, 0, type = "n", xlim = c(0, 10),
ylim = c(0, max(dgamma(seq(0.1, 10, length.out = 100), input$alpha, input$lambda))),
xlab = "Valeurs de x", ylab = "Densité f(x)", cex.lab = 1.2, cex.axis = 1.1,
# bquote() permet d'interpréter dynamiquement les variables en langage mathématique R
main = bquote("Densité pour" ~ alpha == .(input$alpha) ~ "et" ~ lambda == .(input$lambda))
)
# Ajout de la grille
grid(col = "white", lty = "solid", lwd = 1.5)
# Tracé de la courbe
curve(
dgamma(x, shape = input$alpha, rate = input$lambda),
from = 0.01,
to = 10,
col = "#e74c3c",
lwd = 3,
add = TRUE
)
})
}
# 3. Lancement de l'application
shinyApp(ui, server)
